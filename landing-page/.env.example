# Stripe Configuration
# Get these from your Stripe Dashboard (https://dashboard.stripe.com/apikeys)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Google Analytics 4 (Optional)
# Get these from Google Analytics 4 Admin -> Data Streams -> Measurement Protocol API secrets
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=your_ga4_api_secret_here

# Supabase (Optional - for storing analytics events and customer data)
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Environment
NODE_ENV=production

# Domain Configuration (Optional - Netlify will auto-detect)
SITE_URL=https://your-domain.com

# Instructions:
# 1. Copy this file to .env (git will ignore .env files)
# 2. Replace the placeholder values with your actual keys
# 3. For Netlify deployment, add these as environment variables in your Netlify dashboard
# 4. For local development, use: npm install -g netlify-cli && netlify dev