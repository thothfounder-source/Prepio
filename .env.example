# Supabase Configuration
# You'll need to create a Supabase project and get these values from your project settings

# Project URL from Supabase Dashboard -> Settings -> API
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anon/Public key from Supabase Dashboard -> Settings -> API -> Project API keys
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service role key (keep this secret, don't commit to version control)
# Only needed for admin functions or server-side operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key